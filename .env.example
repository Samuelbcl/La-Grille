# Copie ce fichier en ".env.local" et remplis avec tes vraies clés Supabase.
# Tu trouves ces valeurs dans : Supabase Dashboard > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# --- Côté serveur uniquement (à définir dans Vercel, PAS exposés au client) ---
# Nécessaires à la synchro auto des scores (/api/sync-results + cron GitHub Actions) :
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...        # Supabase > Settings > API > service_role (secret)
FOOTBALL_DATA_TOKEN=xxxxxxxxxxxx            # token football-data.org
CRON_SECRET=xxxxxxxxxxxx                    # secret partagé avec le robot (même valeur dans Vercel ET le secret GitHub)
